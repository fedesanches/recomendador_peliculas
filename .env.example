# API key de The Movie Database (TMDB)
# Obtener en: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Fix conflicto OpenMP en macOS (faiss + PyTorch)
KMP_DUPLICATE_LIB_OK=TRUE

# Modo del recomendador: "embedded" (default) o "api"
# En modo "api" el front consume la REST API en RECOMMENDER_API_URL
RECOMMENDER_MODE=embedded
RECOMMENDER_API_URL=http://localhost:8000
